# ─────────────────────────────────────────────────────
# Lead Management System — Docker Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────

# ── Local PostgreSQL (only used when NOT using Supabase) ──
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=lms_pass
POSTGRES_DB=lead_management

# ── Database ──
# For local Docker postgres:
DATABASE_URL=postgresql://postgres.xiwlmbuadywvhqjezpmk:8830781382Soham@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# For Supabase (comment out the line above and use this):
# DATABASE_URL=postgresql://postgres.xiwlmbuadywvhqjezpmk:8830781382Soham@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ── JWT ──
JWT_SECRET=replace_with_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# ── Email (Nodemailer) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
